# Copy this file to .streamlit/secrets.toml (same folder) and fill in your
# real key for local testing. Never commit the real secrets.toml file.
#
# When deploying on Streamlit Community Cloud, paste these same two lines
# (with your real key) into the app's Settings > Secrets box instead. That
# is the only place the real key needs to exist, it never goes in the repo.

GEMINI_API_KEY = "your-gemini-api-key-here"
GEMINI_MODEL = "gemini-flash-lite-latest"
